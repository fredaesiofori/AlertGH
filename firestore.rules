rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Incidents: anyone can read/create, only authenticated responders can update/delete
    match /incidents/{incidentId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
        'title', 'category', 'region', 'city', 'description',
        'severity', 'reportedAt', 'reportedBy', 'status',
        'upvotes', 'downvotes', 'verificationScore'
      ])
      && request.resource.data.title is string
      && request.resource.data.title.size() <= 200
      && request.resource.data.description is string
      && request.resource.data.description.size() <= 2000
      && request.resource.data.upvotes == 1
      && request.resource.data.downvotes == 0
      && request.resource.data.status == 'active';
      allow update: if request.auth != null
        || (
          // Citizens can only update vote counts
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvotes', 'downvotes', 'verificationScore'])
        );
      allow delete: if request.auth != null;
    }

    // Emergency contacts: read-only for public, write only for authenticated responders
    match /emergency_contacts/{contactId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
